# Credenciales del contenedor Docker definidas en docker-compose.yml
DATABASE_URL="postgresql://comics_user:comics_pass@localhost:5432/comic_ecommerce"

# Genera tu propio secreto con: openssl rand -base64 32
SESSION_SECRET="cambiar_por_secreto_seguro"

PORT=3000

# Cloudinary para subir portadas de comics desde el panel admin/vendedor
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# n8n
N8N_BASE_URL=http://localhost:5678
FRONTEND_URL=http://localhost:5173

# MercadoPago
MP_ACCESS_TOKEN=TEST-tu-access-token-aqui
MERCADOPAGO_WEBHOOK_SECRET="tu_webhook_secret"

# URL publica del backend (usar ngrok en desarrollo para el webhook de MP)
BACKEND_URL=https://tu-ngrok-url.ngrok.io
