generator client {
  provider = "prisma-client-js"
}


// URL is provided via prisma.config.ts (Prisma 6+ pattern)
datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(CLIENT)
  phone     String?
  avatarUrl String?
  cuil      String?   @unique
  country              String?
  birthDate            DateTime?
  emailVerified        Boolean   @default(false)
  verificationToken    String?   @unique
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  cart      CartItem[]
  orders    Order[]
  reviews   Review[]
  favorites Comic[]   @relation("Favorites")
  sellerComics Comic[] @relation("SellerComics")
}

enum Role {
  CLIENT
  ADMIN
  SELLER
}

model Comic {
  id          Int        @id @default(autoincrement())
  title       String
  author      String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  stock       Int        @default(0)
  imageUrl    String?
  category    String?
  language    String?
  publisher   String?
  pages       Int?
  edition     String?
  issueNumber String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  seller       User?      @relation("SellerComics", fields: [sellerId], references: [id])
  sellerId     Int?
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  favoritedBy User[]     @relation("Favorites")
}

model CartItem {
  id       Int   @id @default(autoincrement())
  user     User  @relation(fields: [userId], references: [id])
  userId   Int
  comic    Comic @relation(fields: [comicId], references: [id])
  comicId  Int
  quantity Int   @default(1)

  @@unique([userId, comicId])
}

model Order {
  id        Int         @id @default(autoincrement())
  user      User        @relation(fields: [userId], references: [id])
  userId    Int
  status    OrderStatus @default(PENDING)
  total     Decimal   @db.Decimal(10, 2)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  order    Order @relation(fields: [orderId], references: [id])
  orderId  Int
  comic    Comic @relation(fields: [comicId], references: [id])
  comicId  Int
  quantity Int
  price    Decimal   @db.Decimal(10, 2)
}

model Review {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  comic     Comic    @relation(fields: [comicId], references: [id])
  comicId   Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, comicId])
}
